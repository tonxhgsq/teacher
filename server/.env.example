# 复制此文件为 .env 并填入真实值

# 火山引擎 Ark OpenAI-compatible API
VOLCENGINE_API_KEY=your_volcengine_api_key
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
VOLCENGINE_MODEL=your_volcengine_model_or_endpoint_id

# 用于加密保存飞书 App Secret；生产环境请使用独立随机长密钥
FEISHU_CREDENTIAL_KEY=replace_with_a_long_random_secret

# 邮箱验证码（生产环境必须配置；开发环境未配置时会返回 devCode）
# 推荐生产使用腾讯云邮件推送：MAIL_PROVIDER=tencent
MAIL_PROVIDER=
TENCENTCLOUD_SECRET_ID=your_tencentcloud_secret_id
TENCENTCLOUD_SECRET_KEY=your_tencentcloud_secret_key
TENCENT_SES_FROM_EMAIL=no-reply@example.com
TENCENT_SES_REGION=ap-hongkong
TENCENT_SES_ENDPOINT=ses.ap-hongkong.tencentcloudapi.com
TENCENT_SES_TEMPLATE_ID=186181

# 也可继续使用 SMTP：MAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
MAIL_FROM="AI 学情工作台 <no-reply@example.com>"

# 积分
INITIAL_CREDITS=1280
ENABLE_CREDIT_GRANT=false

# 服务端口
PORT=3001
HOST=127.0.0.1

# 生产安全
# 生产环境建议设置 NODE_ENV=production，并填写正式域名白名单，例如：
# CORS_ORIGINS=https://teacher.example.com
CORS_ORIGINS=
TRUST_PROXY=false
RATE_LIMIT_DISABLED=false

# 备份与上传图片
# 默认数据库：../data/teacher.db
# 默认题内截图目录：../frontend/src/uploads/question-images
# 默认备份目录：../data/backups
DB_PATH=data/teacher.db
QUESTION_IMAGES_DIR=frontend/src/uploads/question-images
BACKUP_DIR=data/backups
